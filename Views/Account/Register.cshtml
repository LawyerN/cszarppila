@{
    ViewData["Title"] = "Rejestracja";
}

<div class="flex justify-center items-center min-h-[70vh] py-8">
    <div class="max-w-md w-full bg-gray-800 rounded-lg shadow-xl p-8 border border-gray-700">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold text-blue-400">Dołącz do nas</h2>
            <p class="text-gray-400 mt-2 text-sm">Utwórz nowe konto w systemie Football Score.</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-950 border border-red-800 text-red-200 px-4 py-3 rounded-md mb-6 text-sm text-center shadow-inner">
                @ViewBag.Error
            </div>
        }

        <form asp-controller="Account" asp-action="Register" method="post">
            
            <div class="mb-5">
                <label for="username" class="block text-gray-300 mb-2 font-medium text-sm">Nazwa użytkownika</label>
                <input type="text" id="username" name="username" class="w-full bg-gray-700 border border-gray-600 rounded-md text-white px-4 py-2.5 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition" required placeholder="Wybierz swój login..." />
            </div>

            <div class="mb-5">
                <label for="password" class="block text-gray-300 mb-2 font-medium text-sm">Hasło</label>
                <input type="password" id="password" name="password" class="w-full bg-gray-700 border border-gray-600 rounded-md text-white px-4 py-2.5 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition" required placeholder="Utwórz silne hasło..." />
            </div>

            <div class="mb-6">
                <label for="confirmPassword" class="block text-gray-300 mb-2 font-medium text-sm">Potwierdź hasło</label>
                <input type="password" id="confirmPassword" name="confirmPassword" class="w-full bg-gray-700 border border-gray-600 rounded-md text-white px-4 py-2.5 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition" required placeholder="Powtórz hasło..." />
            </div>

            <div>
                <button type="submit" class="w-full bg-green-600 hover:bg-green-500 text-white font-bold py-2.5 px-4 rounded-md shadow transition duration-200 cursor-pointer">
                    Zarejestruj się
                </button>
            </div>
        </form>

        <div class="text-center mt-6 text-sm text-gray-400 border-t border-gray-700 pt-5">
            Masz już konto? 
            <a asp-controller="Account" asp-action="Login" class="text-blue-400 hover:text-blue-300 hover:underline transition font-medium">Zaloguj się tu</a>
        </div>
    </div>
</div>