@{
    ViewData["Title"] = "Dashboard La Liga";
}

@functions {
    public string Pluralize(int count, string one, string few, string many)
    {
        if (count == 1) return one;
        if (count % 10 >= 2 && count % 10 <= 4 && (count % 100 < 10 || count % 100 >= 20)) 
            return few;
        return many;
    }
}

<div class="mb-8">
    <h1 class="text-3xl font-bold text-blue-400">System Zarządzania Rozgrywkami La Liga</h1>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-gray-800 rounded-lg shadow-md p-5 border-l-4 border-blue-500 flex flex-col items-start justify-center">
        <div class="text-gray-400 text-sm uppercase tracking-wide">Drużyny</div>
        <div class="text-3xl font-bold text-white">@(ViewBag.AllTeams?.Count ?? 0)</div>
    </div>
    <div class="bg-gray-800 rounded-lg shadow-md p-5 border-l-4 border-blue-500 flex flex-col items-start justify-center">
        <div class="text-gray-400 text-sm uppercase tracking-wide">Zawodnicy</div>
        <div class="text-3xl font-bold text-white">@(ViewBag.AllPlayers?.Count ?? 0)</div>
    </div>
    <div class="bg-gray-800 rounded-lg shadow-md p-5 border-l-4 border-blue-500 flex flex-col items-start justify-center">
        <div class="text-gray-400 text-sm uppercase tracking-wide">Stadiony</div>
        <div class="text-3xl font-bold text-white">@(ViewBag.AllStadiums?.Count ?? 0)</div>
    </div>
    <div class="bg-gray-800 rounded-lg shadow-md p-5 border-l-4 border-blue-500 flex flex-col items-start justify-center">
        <div class="text-gray-400 text-sm uppercase tracking-wide">Sędziowie</div>
        <div class="text-3xl font-bold text-white">@(ViewBag.AllReferees?.Count ?? 0)</div>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-gray-800 rounded-lg shadow-md overflow-hidden">
        <div class="bg-blue-800 px-4 py-2">
            <h3 class="font-semibold text-white">Najskuteczniejsi Strzelcy</h3>
        </div>
        <div class="p-4">
            @if (ViewBag.TopScorers != null && ViewBag.TopScorers.Count > 0)
            {
                @foreach (var s in ViewBag.TopScorers)
                {
                    <div class="flex justify-between items-center border-b border-gray-700 py-2">
                        <div>
                            <span class="font-medium text-white">@s.PlayerName</span>
                            <span class="text-gray-400 text-sm ml-2">(@s.TeamName)</span>
                        </div>
                        <span class="bg-blue-900 text-blue-200 text-xs font-semibold px-3 py-2 rounded-sm">
                            @s.Goals @Pluralize(s.Goals, "gol", "gole", "goli")
                        </span>
                    </div>
                }
            }
            else
            {
                <p class="text-gray-400">Brak danych</p>
            }
            <div class="mt-3 text-center">
                <a href="/Stats/TopScorers" class="text-blue-400 text-sm hover:underline">Pełne zestawienie</a>
            </div>
        </div>
    </div>

    <div class="bg-gray-800 rounded-lg shadow-md overflow-hidden">
        <div class="bg-blue-800 px-4 py-2">
            <h3 class="font-semibold text-white">Gole na stadionach</h3>
        </div>
        <div class="p-4">
            @if (ViewBag.TopStadiumStats != null && ViewBag.TopStadiumStats.Count > 0)
            {
                @foreach (var st in ViewBag.TopStadiumStats)
                {
                    <div class="flex justify-between items-center border-b border-gray-700 py-2">
                        <span class="font-medium text-white">@st.StadiumName</span>
                        <span class="bg-blue-900 text-blue-200 text-xs font-semibold px-3 py-2 rounded-sm">
                            @st.TotalGoals @Pluralize(st.TotalGoals, "bramka", "bramki", "bramek")
                        </span>
                    </div>
                }
            }
            else
            {
                <p class="text-gray-400">Brak danych</p>
            }
            <div class="mt-3 text-center">
                <a href="/Stats/StadiumGoals" class="text-blue-400 text-sm hover:underline">Pełne zestawienie</a>
            </div>
        </div>
    </div>

    <div class="bg-gray-800 rounded-lg shadow-md overflow-hidden">
        <div class="bg-blue-800 px-4 py-2">
            <h3 class="font-semibold text-white">Aktywność Sędziów</h3>
        </div>
        <div class="p-4">
            @if (ViewBag.TopRefereeStats != null && ViewBag.TopRefereeStats.Count > 0)
            {
                @foreach (var refStat in ViewBag.TopRefereeStats)
                {
                    <div class="flex justify-between items-center border-b border-gray-700 py-2">
                        <span class="font-medium text-white">@refStat.Name</span>
                        <span class="bg-blue-900 text-blue-200 text-xs font-semibold px-3 py-2 rounded-sm">
                            @refStat.MatchesOfficiated  @Pluralize(refStat.MatchesOfficiated , "spotkanie", "spotkania", "spotkań")
                        </span>
                    </div>
                }
            }
            else
            {
                <p class="text-gray-400">Brak danych</p>
            }
            <div class="mt-3 text-center">
                <a href="/Stats/Referees" class="text-blue-400 text-sm hover:underline">Pełne zestawienie</a>
            </div>
        </div>
    </div>
</div>

<div class="bg-gray-800 rounded-lg shadow-md overflow-hidden mb-8">
    <div class="bg-blue-800 px-4 py-2 flex justify-between items-center">
        <h3 class="font-semibold text-white">Najbliższe / Ostatnie mecze</h3>
    </div>
    <div class="p-4">
        @if (ViewBag.RecentMatches != null && ViewBag.RecentMatches.Count > 0)
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                @foreach (var match in ViewBag.RecentMatches)
                {
                    <div class="bg-gray-700 rounded-lg p-4 hover:shadow-lg transition-shadow border border-gray-600">
                        <div class="flex justify-between items-center mb-3">
                            <div class="flex-1 text-center">
                                <span class="font-semibold text-white">@match.HomeTeam?.Name</span>
                            </div>
                            <div class="mx-2 text-lg font-bold text-blue-400">
                                @if (match.IsCompleted)
                                {
                                    <span>@match.HomeScore : @match.AwayScore</span>
                                }
                                else
                                {
                                    <span class="text-gray-400 text-sm">vs</span>
                                }
                            </div>
                            <div class="flex-1 text-center">
                                <span class="font-semibold text-white">@match.AwayTeam?.Name</span>
                            </div>
                        </div>

                        <!-- Match Info Footer -->
                        <div class="flex justify-between items-center text-xs text-gray-400 border-t border-gray-600 pt-2 mt-2">
                            <div class="flex items-center gap-1">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                                <span>@match.MatchDate.ToString("dd.MM.yyyy HH:mm")</span>
                            </div>
                            <div>
                                <span>@match.Stadium?.Name</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-gray-400">Brak meczów do wyświetlenia.</p>
        }
    </div>
    <div class="mt-3 pb-3 text-center">
        <a href="/Matches" class="text-blue-400 text-sm hover:underline">Pełne zestawienie</a>
    </div>
</div>

@if (User.IsInRole("Admin")) {
<div class="bg-gray-800 rounded-lg shadow-md p-6">
    <h3 class="text-xl font-semibold text-white mb-4">Zarządzanie</h3>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/Teams" 
           class="flex items-center justify-center gap-2 bg-blue-800 hover:bg-blue-500 text-white font-medium py-2 px-4 rounded-md transition text-center">
            Drużyny
        </a>
        <a href="/Players" 
           class="flex items-center justify-center gap-2 bg-blue-800 hover:bg-blue-500 text-white font-medium py-2 px-4 rounded-md transition text-center">
            Zawodnicy
        </a>
        <a href="/Infrastructure" 
           class="flex items-center justify-center gap-2 bg-blue-800 hover:bg-blue-500 text-white font-medium py-2 px-4 rounded-md transition text-center">
            Stadiony i Sędziowie
        </a>
    </div>
    <div class="mt-4 pt-3 border-t border-gray-700 text-center text-sm text-gray-400">
        Jesteś administratorem, możesz edytować powyższe dane.
    </div>
</div>
}