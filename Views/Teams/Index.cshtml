@model IEnumerable<FootballScoreApp.Models.Team>
@{
    ViewData["Title"] = "Zespoły La Liga";
}

<div class="mb-6 flex justify-between items-center">
    <h1 class="text-3xl font-bold text-blue-400">Kluby Piłkarskie</h1>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="bg-blue-800 hover:bg-blue-500 text-white px-3 py-2 rounded-md text-sm transition">Dodaj nowy klub</a>
    }
</div>

<div class="bg-gray-800 rounded-lg shadow-md overflow-hidden">
    <table class="min-w-full text-left">
        <thead class="bg-gray-700 text-gray-300">
            <tr>
                <th class="px-6 py-3 border-b border-gray-600">Nazwa</th>
                <th class="px-6 py-3 border-b border-gray-600">Skrót</th>
                <th class="px-6 py-3 border-b border-gray-600">Rok założenia</th>
                <th class="px-6 py-3 border-b border-gray-600">Stadion</th>
                @if (User.IsInRole("Admin")) { <th class="px-6 py-3 border-b border-gray-600">Akcje</th> }
            </tr>
        </thead>
        <tbody class="text-gray-200">
            @foreach (var item in Model)
            {
                <tr class="hover:bg-gray-750 border-b border-gray-700">
                    <td class="px-6 py-4 font-semibold text-white">@item.Name</td>
                    <td class="px-6 py-4"><span class="bg-blue-900 text-blue-200 text-xs px-2 py-1 rounded-full">@item.ShortName</span></td>
                    <td class="px-6 py-4">@item.Founded</td>
                    <td class="px-6 py-4">@(item.Stadium?.Name ?? "Brak stadionu")</td>
                    @if (User.IsInRole("Admin"))
                    {
                        <td class="px-6 py-4 space-x-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="text-blue-400 hover:text-blue-300 text-sm hover:underline">Edytuj</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="text-red-400 hover:text-red-300 text-sm hover:underline">Usuń</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>