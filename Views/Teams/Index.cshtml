@model IEnumerable<FootballScoreApp.Models.Team>

@{
    ViewData["Title"] = "Zespoły La Liga";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Kluby Piłkarskie</h2>
    <a asp-action="Create" class="btn btn-success">➕ Dodaj nowy klub</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
    <tr>
        <th>Nazwa</th>
        <th>Skrót</th>
        <th>Rok założenia</th>
        <th>Stadion</th>
        <th>Akcje</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td><strong>@item.Name</strong></td>
            <td><span class="badge bg-secondary">@item.ShortName</span></td>
            <td>@item.Founded</td>
            <td>@(item.Stadium?.Name ?? "Brak stadionu")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edytuj</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Usuń</a>
            </td>
        </tr>
    }
    </tbody>
</table>