@model FootballScoreApp.Models.Team

@{
    ViewData["Title"] = "Edytuj Klub";
}

<h2>Edycja klubu: @Model.Name</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label">Nazwa klubu</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ShortName" class="control-label">Skrót (np. BAR, RMA)</label>
                <input asp-for="ShortName" class="form-control" required />
                <span asp-validation-for="ShortName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Founded" class="control-label">Rok założenia</label>
                <input asp-for="Founded" type="number" class="form-control" />
                <span asp-validation-for="Founded" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="StadiumId" class="control-label">Stadion domowy</label>
                <select asp-for="StadiumId" class="form-control" asp-items="@(new SelectList(ViewBag.Stadiums, "Id", "Name"))">
                    <option value="">-- Wybierz stadion --</option>
                </select>
                <span asp-validation-for="StadiumId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Zapisz zmiany" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}