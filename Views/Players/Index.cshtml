@model IEnumerable<FootballScoreApp.Models.Player>
@{
    ViewData["Title"] = "Zawodnicy";
}

<div class="mb-6 flex justify-between items-center">
    <h1 class="text-3xl font-bold text-blue-400">Zawodnicy</h1>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="bg-blue-800 hover:bg-blue-500 text-white px-3 py-2 rounded-md text-sm transition">Dodaj zawodnika</a>
    }
</div>

<div class="bg-gray-800 rounded-lg shadow-md overflow-hidden">
    <table class="min-w-full text-left">
        <thead class="bg-gray-700 text-gray-300">
            <tr>
                <th class="px-6 py-3 border-b border-gray-600">Imię i Nazwisko</th>
                <th class="px-6 py-3 border-b border-gray-600">Klub</th>
                @if (User.IsInRole("Admin")) { <th class="px-6 py-3 border-b border-gray-600 text-right">Akcje</th> }
            </tr>
        </thead>
        <tbody class="text-gray-200">
            @foreach (var player in Model)
            {
                <tr class="hover:bg-gray-750 border-b border-gray-700">
                    <td class="px-6 py-4 font-medium text-white">@player.FirstName @player.LastName</td>
                    <td class="px-6 py-4 text-gray-400">@(player.Team?.Name ?? "-")</td>
                    @if (User.IsInRole("Admin"))
                    {
                        <td class="px-6 py-4 space-x-2 text-right">
                            <a asp-action="Edit" asp-route-id="@player.Id" class="text-blue-400 hover:text-blue-300 text-sm hover:underline">Edytuj</a>
                            <a asp-action="Delete" asp-route-id="@player.Id" class="text-red-400 hover:text-red-300 text-sm hover:underline">Usuń</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>