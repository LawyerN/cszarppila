@model FootballScoreApp.Models.Player

<div class="alert alert-danger m-3">
    <h3>Czy na pewno chcesz usunąć zawodnika @Model.FullName?</h3>
    <p>Tej operacji nie da się cofnąć.</p>
</div>

<form asp-controller="Players" asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Potwierdź usunięcie" class="btn btn-danger" />
    <a href="/Home/Index" class="btn btn-secondary">Anuluj</a>
</form>