@model IEnumerable<FootballScoreApp.Controllers.StadiumStatsViewModel>
@{
    ViewData["Title"] = "Gole na Stadionach";
}

<div class="mb-6">
    <h1 class="text-3xl font-bold text-blue-400">Gole na Stadionach</h1>
    <p class="text-gray-400 text-sm mt-1">Ranking obiektów według łącznej liczby trafień w rozegranych meczach</p>
</div>

<div class="bg-gray-800 rounded-lg shadow-md overflow-hidden">
    <table class="min-w-full text-left">
        <thead class="bg-gray-700 text-gray-300">
            <tr>
                <th class="px-6 py-3 border-b border-gray-600 w-12 text-center">#</th>
                <th class="px-6 py-3 border-b border-gray-600">Stadion</th>
                <th class="px-6 py-3 border-b border-gray-600 text-center">Rozegrane mecze</th>
                <th class="px-6 py-3 border-b border-gray-600 text-center">Suma bramek</th>
                <th class="px-6 py-3 border-b border-gray-600 text-center">Średnia / mecz</th>
            </tr>
        </thead>
        <tbody class="text-gray-200 divide-y divide-gray-700">
            @{ int index = 1; }
            @foreach (var item in Model)
            {
                double average = item.MatchesCount > 0 ? Math.Round((double)item.TotalGoals / item.MatchesCount, 2) : 0;
                <tr class="hover:bg-gray-750 transition-colors">
                    <td class="px-6 py-4 text-center font-bold text-gray-500">@(index++)</td>
                    <td class="px-6 py-4 font-semibold text-white">@item.StadiumName</td>
                    <td class="px-6 py-4 text-center text-gray-300">@item.MatchesCount</td>
                    <td class="px-6 py-4 text-center font-bold text-blue-400 text-lg">@item.TotalGoals</td>
                    <td class="px-6 py-4 text-center text-gray-400">@average.ToString("0.00")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-6">
    <a href="/" class="text-blue-400 hover:text-blue-300 hover:underline text-sm transition">← Powrót do pulpitu</a>
</div>