@model IEnumerable<FootballScoreApp.Controllers.TopScorerViewModel>
@{
    ViewData["Title"] = "Pełne Zestawienie Strzelców";
    string sortBy = ViewBag.SortBy ?? "goals";
}

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
        <h1 class="text-3xl font-bold text-blue-400">Statystyki Zawodników</h1>
        <p class="text-gray-400 text-sm mt-1">Pełne zestawienie zdobywców bramek i asyst w La Liga</p>
    </div>
    
    <div class="flex bg-gray-800 p-1 rounded-md border border-gray-700">
        <a href="?sortBy=goals" class="px-4 py-2 rounded-md text-sm font-medium transition @(sortBy == "goals" ? "bg-blue-600 text-white" : "text-gray-400 hover:text-white")">
            Gole
        </a>
        <a href="?sortBy=assists" class="px-4 py-2 rounded-md text-sm font-medium transition @(sortBy == "assists" ? "bg-blue-600 text-white" : "text-gray-400 hover:text-white")">
            Asysty
        </a>
    </div>
</div>

<div class="bg-gray-800 rounded-lg shadow-md overflow-hidden">
    <table class="min-w-full text-left">
        <thead class="bg-gray-700 text-gray-300">
            <tr>
                <th class="px-6 py-3 border-b border-gray-600 w-12 text-center">#</th>
                <th class="px-6 py-3 border-b border-gray-600">Zawodnik</th>
                <th class="px-6 py-3 border-b border-gray-600">Klub</th>
                <th class="px-6 py-3 border-b border-gray-600 text-center">Gole</th>
                <th class="px-6 py-3 border-b border-gray-600 text-center">Asysty</th>
            </tr>
        </thead>
        <tbody class="text-gray-200 divide-y divide-gray-700">
            @{ int index = 1; }
            @foreach (var item in Model)
            {
                <tr class="hover:bg-gray-750 transition-colors">
                    <td class="px-6 py-4 text-center font-bold text-gray-500">@(index++)</td>
                    <td class="px-6 py-4 font-semibold text-white">@item.PlayerName</td>
                    <td class="px-6 py-4 text-gray-400">@item.TeamName</td>
                    <td class="px-6 py-4 text-center font-bold @(sortBy == "goals" ? "text-blue-400 text-lg" : "")">@item.Goals</td>
                    <td class="px-6 py-4 text-center font-bold @(sortBy == "assists" ? "text-blue-400 text-lg" : "")">@item.Assists</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-6">
    <a href="/" class="text-blue-400 hover:text-blue-300 hover:underline text-sm transition">← Powrót do pulpitu</a>
</div>