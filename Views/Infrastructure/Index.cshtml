@{
    ViewData["Title"] = "Infrastruktura i Sędziowie";
    var stadiums = ViewBag.Stadiums as IEnumerable<FootballScoreApp.Models.Stadium>;
    var referees = ViewBag.Referees as IEnumerable<FootballScoreApp.Models.Referee>;
}

<div class="mb-8">
    <h1 class="text-3xl font-bold text-blue-400">Infrastruktura i Arbitrzy</h1>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    
    <div>
        <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-semibold text-white">Stadiony</h2>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="CreateStadium" class="bg-blue-800 hover:bg-blue-500 text-white px-3 py-2 rounded-md text-sm transition">Dodaj Stadion</a>
            }
        </div>
        <div class="bg-gray-800 rounded-lg shadow-md overflow-hidden">
            <table class="min-w-full text-left">
                <thead class="bg-gray-700 text-gray-300">
                    <tr>
                        <th class="px-4 py-2 border-b border-gray-600">Nazwa</th>
                        @if (User.IsInRole("Admin")) { <th class="px-4 py-2 border-b border-gray-600 text-right">Akcja</th> }
                    </tr>
                </thead>
                <tbody class="text-gray-200">
                    @if(stadiums != null && stadiums.Any()) {
                        foreach (var s in stadiums)
                        {
                            @if (s.Name == null) continue; 
                            <tr class="border-b border-gray-700">
                                <td class="px-4 py-3 text-white">@s.Name</td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <td class="px-4 py-3 text-right">
                                        <a asp-action="DeleteStadium" asp-route-id="@s.Id" class="text-red-400 hover:text-red-300 text-sm hover:underline">Usuń</a>
                                    </td>
                                }
                            </tr>
                        }
                    } else {
                        <tr><td colspan="2" class="px-4 py-3 text-gray-500">Brak stadionów</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div>
        <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-semibold text-white">Sędziowie</h2>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="CreateReferee" class="bg-blue-800 hover:bg-blue-500 text-white px-3 py-2 rounded-md text-sm transition">Dodaj Sędziego</a>
            }
        </div>
        <div class="bg-gray-800 rounded-lg shadow-md overflow-hidden">
            <table class="min-w-full text-left">
                <thead class="bg-gray-700 text-gray-300">
                    <tr>
                        <th class="px-4 py-2 border-b border-gray-600">Imię i Nazwisko</th>
                        @if (User.IsInRole("Admin")) { <th class="px-4 py-2 border-b border-gray-600 text-right">Akcja</th> }
                    </tr>
                </thead>
                <tbody class="text-gray-200">
                    @if(referees != null && referees.Any()) {
                        foreach (var r in referees)
                        {
                            <tr class="border-b border-gray-700">
                                <td class="px-4 py-3 text-white">@r.FirstName @r.LastName</td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <td class="px-4 py-3 text-right">
                                        <a asp-action="DeleteReferee" asp-route-id="@r.Id" class="text-red-400 hover:text-red-300 text-sm hover:underline">Usuń</a>
                                    </td>
                                }
                            </tr>
                        }
                    } else {
                        <tr><td colspan="2" class="px-4 py-3 text-gray-500">Brak sędziów</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>