@model FootballScoreApp.Models.Referee

@{
    ViewData["Title"] = "Zarejestruj sędziego";
}

@if (User.IsInRole("Admin")) 
{
    <div class="mb-6">
        <h1 class="text-3xl font-bold text-blue-400">Zarejestruj nowego sędziego</h1>
    </div>

    <div class="bg-gray-800 rounded-lg shadow-md p-6 max-w-lg">
        <form asp-action="CreateReferee" method="post">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4"></div>

            <div class="mb-4">
                <label asp-for="FirstName" class="block text-gray-300 mb-2 font-medium">Imię</label>
                <input asp-for="FirstName" class="w-full bg-gray-700 border border-gray-600 rounded-md text-white px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition" required />
                <span asp-validation-for="FirstName" class="text-red-400 text-sm mt-1 block"></span>
            </div>

            <div class="mb-4">
                <label asp-for="LastName" class="block text-gray-300 mb-2 font-medium">Nazwisko</label>
                <input asp-for="LastName" class="w-full bg-gray-700 border border-gray-600 rounded-md text-white px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition" required />
                <span asp-validation-for="LastName" class="text-red-400 text-sm mt-1 block"></span>
            </div>

            <div class="mb-6">
                <label asp-for="Nationality" class="block text-gray-300 mb-2 font-medium">Narodowość</label>
                <input asp-for="Nationality" class="w-full bg-gray-700 border border-gray-600 rounded-md text-white px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition" required />
                <span asp-validation-for="Nationality" class="text-red-400 text-sm mt-1 block"></span>
            </div>

            <div class="flex items-center justify-between border-t border-gray-700 pt-4 mt-2">
                <input type="submit" value="Zapisz sędziego" class="bg-yellow-600 hover:bg-yellow-500 text-white font-bold py-2 px-4 rounded shadow cursor-pointer transition" />
                <a href="/Infrastructure" class="text-blue-400 hover:text-blue-300 hover:underline transition text-sm">Powrót</a>
            </div>
        </form>
    </div>
}