@model FootballScoreApp.Models.Stadium

<h2>Dodaj nowy obiekt (Stadion)</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="CreateStadium" method="post">
            <div class="form-group mb-3">
                <label class="control-label">Nazwa stadionu</label>
                <input asp-for="Name" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Miasto</label>
                <input asp-for="City" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Pojemność trybun</label>
                <input asp-for="Capacity" type="number" class="form-control" required />
            </div>
            <div class="form-group">
                <input type="submit" value="Zapisz stadion" class="btn btn-success" />
                <a href="/Home/Index" class="btn btn-secondary">Powrót</a>
            </div>
        </form>
    </div>
</div>